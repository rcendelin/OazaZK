# Entra ID configuration
# WARNING: All VITE_ prefixed variables are PUBLIC — they are embedded in the
# client-side JavaScript bundle. Never put secrets here.
VITE_ENTRA_CLIENT_ID=your-client-id-here
VITE_ENTRA_TENANT_ID=your-tenant-id-here

# API base URL (for direct Functions call without SWA proxy)
# Leave empty or omit to use default '/api' (works with SWA Linked Backend)
# Set to Functions URL for Free SWA tier: https://func-oaza-dev.azurewebsites.net/api
VITE_API_BASE_URL=
